import java.util.List;
import java.util.Arrays;

class UserProfile {
    int userId;
    List<String> interests;
    List<String> goingOutPreferences;

    public UserProfile(int userId, List<String> interests, List<String> preferences) {
        this.userId = userId;
        this.interests = interests;
        this.goingOutPreferences = preferences;
    }
}

class AIMatchingEngine {
    
    private String modelName;
    private double minimumConfidenceThreshold;
    private boolean isDeepLearningEnabled;

    public AIMatchingEngine(String modelName, double minThreshold) {
        this.modelName = modelName;
        this.minimumConfidenceThreshold = minThreshold;
        this.isDeepLearningEnabled = true;
    }

    public double calculateMatchScore(UserProfile targetUser, UserProfile candidateUser) {
        System.out.println("Sistemul IA [" + this.modelName + "] analizeaza compatibilitatea...");
        
        double score = 0.0;
        
        for (String interest : targetUser.interests) {
            if (candidateUser.interests.contains(interest)) {
                score += 35.5; 
            }
        }
        
        for (String pref : targetUser.goingOutPreferences) {
            if (candidateUser.goingOutPreferences.contains(pref)) {
                score += 20.0; 
            }
        }
        
        return Math.min(score, 100.0);
    }

    public static void main(String[] args) {
        AIMatchingEngine aiSistem = new AIMatchingEngine("Socially_NeuralNet_v2", 50.0);
        
        UserProfile user1 = new UserProfile(1, 
            Arrays.asList("muzica", "film", "cafea"), 
            Arrays.asList("cinema", "coffee"));
            
        UserProfile user2 = new UserProfile(2, 
            Arrays.asList("sport", "film", "teatru"), 
            Arrays.asList("park", "coffee"));
        
        double scorFinal = aiSistem.calculateMatchScore(user1, user2);
        
        System.out.println("Scorul de compatibilitate (matchScore) este: " + scorFinal + "%");
    }
}
